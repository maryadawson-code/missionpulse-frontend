{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://missionpulse.ai/schemas/rbac-truth/v2.0.0",
  "title": "MissionPulse RBAC Truth Schema",
  "description": "Validation schema for roles_permissions_config.json. The canonical RBAC matrix defines what each role can see and do in each module. This schema enforces structural integrity.",
  "type": "object",

  "properties": {
    "version": {
      "type": "string",
      "description": "Config version (e.g., '9.5')"
    },
    "lastUpdated": {
      "type": "string",
      "description": "ISO date of last update"
    },
    "roles": {
      "type": "object",
      "description": "12 canonical roles, each containing module permissions",
      "propertyNames": {
        "enum": [
          "executive",
          "operations",
          "capture_manager",
          "proposal_manager",
          "volume_lead",
          "pricing_manager",
          "contracts",
          "hr_staffing",
          "author",
          "partner",
          "subcontractor",
          "consultant"
        ]
      },
      "additionalProperties": {
        "$ref": "#/definitions/RoleDefinition"
      },
      "minProperties": 12,
      "maxProperties": 12
    }
  },
  "required": ["version", "roles"],

  "definitions": {
    "RoleDefinition": {
      "type": "object",
      "description": "A role's permissions across all 14 modules",
      "properties": {
        "displayName": { "type": "string" },
        "description": { "type": "string" },
        "isInternal": { "type": "boolean" },
        "modules": {
          "type": "object",
          "propertyNames": {
            "enum": [
              "dashboard",
              "pipeline",
              "proposals",
              "pricing",
              "strategy",
              "blackhat",
              "compliance",
              "workflow_board",
              "ai_chat",
              "documents",
              "analytics",
              "admin",
              "integrations",
              "audit_log"
            ]
          },
          "additionalProperties": {
            "$ref": "#/definitions/ModulePermission"
          },
          "minProperties": 14,
          "maxProperties": 14
        }
      },
      "required": ["displayName", "isInternal", "modules"]
    },

    "ModulePermission": {
      "type": "object",
      "description": "Permission triple for one role in one module. All three booleans required.",
      "properties": {
        "shouldRender": {
          "type": "boolean",
          "description": "If false, the module component does not exist in the DOM for this role (invisible RBAC)"
        },
        "canView": {
          "type": "boolean",
          "description": "If true, the user can read data in this module"
        },
        "canEdit": {
          "type": "boolean",
          "description": "If true, the user can create/update/delete data in this module"
        },
        "scopeRestriction": {
          "type": "string",
          "description": "Optional scope limit for external roles (e.g., 'assigned_opportunities_only')"
        }
      },
      "required": ["shouldRender", "canView", "canEdit"],
      "additionalProperties": false,

      "allOf": [
        {
          "if": { "properties": { "shouldRender": { "const": false } } },
          "then": {
            "properties": {
              "canView": { "const": false },
              "canEdit": { "const": false }
            }
          }
        },
        {
          "if": { "properties": { "canEdit": { "const": true } } },
          "then": {
            "properties": {
              "canView": { "const": true }
            }
          }
        }
      ]
    }
  }
}

    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push *)",
      "Bash(git checkout main)",
      "Bash(npm publish *)",
      "Bash(npx supabase db reset *)",
      "Bash(curl * -X DELETE *)"
    ]
  }
}

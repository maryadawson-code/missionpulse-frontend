# ==============================================================================
# MISSIONPULSE - ASKSAGE CONFIGURATION
# ==============================================================================
# Copy this file to .env and fill in your credentials
# NEVER commit .env to version control
# ==============================================================================

# -----------------------------------------------------------------------------
# ASKSAGE AUTHENTICATION (Required)
# -----------------------------------------------------------------------------
# Get these from: AskSage Platform → Settings → Account → Manage API Keys

ASKSAGE_API_KEY=your_api_key_here
ASKSAGE_EMAIL=your_registered_email@company.com

# -----------------------------------------------------------------------------
# ENVIRONMENT SELECTION
# -----------------------------------------------------------------------------
# Options:
#   commercial   - IL2, non-CUI (default, uses api.asksage.ai)
#   fedramp_high - IL5, CUI authorized (uses api.civ.asksage.ai)
#   dod          - NIPR required (uses api.genai.army.mil)

ASKSAGE_ENVIRONMENT=commercial

# -----------------------------------------------------------------------------
# SMART ROUTING CONFIGURATION (Optional)
# -----------------------------------------------------------------------------
# Force all queries to use CUI-authorized models (regardless of content)
FORCE_CUI_MODELS=false

# Enable/disable smart model routing (cost optimization)
ENABLE_SMART_ROUTING=true

# Minimum model tier to use (economy, standard, advanced, critical)
# Overrides classifier decisions that fall below this tier
MIN_MODEL_TIER=economy

# -----------------------------------------------------------------------------
# COST CONTROLS (Optional)
# -----------------------------------------------------------------------------
# Monthly budget cap in USD (0 = unlimited)
MONTHLY_BUDGET_USD=0

# Daily budget cap in USD (0 = unlimited)
DAILY_BUDGET_USD=0

# Alert threshold (percentage of budget)
BUDGET_ALERT_THRESHOLD=80

# -----------------------------------------------------------------------------
# LOGGING & DEBUGGING
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log model routing decisions (helpful for cost analysis)
LOG_ROUTING_DECISIONS=false

# Include routing metadata in API responses
INCLUDE_ROUTING_METADATA=false

# -----------------------------------------------------------------------------
# LEGACY ANTHROPIC CONFIGURATION (DEPRECATED)
# -----------------------------------------------------------------------------
# These are no longer used after AskSage migration
# Kept for reference during transition period

# ANTHROPIC_API_KEY=sk-ant-xxxxx  # DEPRECATED - Remove after migration

# =============================================================================
# MissionPulse — Next.js Environment Variables
# =============================================================================
# Copy to .env.local and fill in values. NEVER commit .env.local.
# Mission Meets Tech — Mission. Technology. Transformation.
# =============================================================================

# Supabase (Required) — Instance: djuviwarqdvlbgcfuupa
NEXT_PUBLIC_SUPABASE_URL=https://djuviwarqdvlbgcfuupa.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# SUPABASE_POOLER_URL=              # Optional: Supabase connection pooler URL

# Site URL (Required) — Must match deployment
# Local: http://localhost:3000
# Staging: https://v2-development--missionpulse.netlify.app
# Production: https://missionpulse.netlify.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=https://missionpulse.ai

# AI Provider Configuration (GTM Extension — T-GTM-1.1)
AI_PRIMARY_PROVIDER=asksage
AI_FALLBACK_PROVIDER=anthropic
# AI_MONTHLY_BUDGET_USD=500
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=
# ASKSAGE_API_KEY=
# ASKSAGE_API_URL=https://api.asksage.ai/v1

# Research Router — Live Intelligence (Optional)
# Perplexity sonar-deep-research for multi-step research (~$5/deep query)
# PERPLEXITY_API_KEY=pplx-your-key-here

# Stripe (Sprint 20 — T-20.4)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# External APIs
# SAM_GOV_API_KEY=
# HUBSPOT_API_KEY=

# Integration OAuth Credentials
# Self-service OAuth: users connect their own accounts via /api/oauth/[provider]
# Register callback URLs: {NEXT_PUBLIC_APP_URL}/api/oauth/{provider}/callback
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_SIGNING_SECRET=
# SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=              # Also reads M365_CLIENT_ID (legacy)
# MICROSOFT_CLIENT_SECRET=          # Also reads M365_CLIENT_SECRET (legacy)
# MICROSOFT_TENANT_ID=common        # Also reads M365_TENANT_ID (legacy)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# HUBSPOT_CLIENT_ID=
# HUBSPOT_CLIENT_SECRET=
# DOCUSIGN_CLIENT_ID=
# DOCUSIGN_CLIENT_SECRET=
# DOCUSIGN_ACCOUNT_ID=
# DOCUSIGN_ENV=sandbox
# GOVWIN_CLIENT_ID=
# GOVWIN_CLIENT_SECRET=

# Caching (Optional)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Error Tracking (Recommended)
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ORG=mission-meets-tech
# SENTRY_PROJECT=missionpulse
# SENTRY_AUTH_TOKEN=sntrys_...

# Cron Job Authentication (Required for /api/cron/daily)
# CRON_SECRET=your-cron-secret-here

# Performance Monitoring (Optional)
# PERF_P95_ALERT_THRESHOLD_MS=2000
# SLOW_QUERY_THRESHOLD_MS=500

# Marketing Analytics (S-GTM-3.5)
# NEXT_PUBLIC_GA4_ID=

# Feature Flags
# NEXT_PUBLIC_ENABLE_AI_CHAT=false
# NEXT_PUBLIC_ENABLE_PARTNER_ACCESS=false

# Seed Script (Development Only)
# SEED_SECRET=your-seed-secret-here

# Edge Functions
# ADMIN_NOTIFICATION_EMAIL=admin@missionpulse.ai

# E2E Testing
# E2E_TEST_EMAIL=
# E2E_TEST_PASSWORD=
